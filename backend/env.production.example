# =============================================================================
# PRIMUS BACKEND - PRODUCTION ENVIRONMENT CONFIGURATION (EXAMPLE)
# =============================================================================
# Copy this file to .env for production deployment

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL=postgresql+psycopg2://primus_user:YOUR_SECURE_PASSWORD@db:5432/primus_db

POSTGRES_USER=primus_user
POSTGRES_PASSWORD=YOUR_SECURE_PASSWORD
POSTGRES_DB=primus_db

# =============================================================================
# SECURITY KEYS
# =============================================================================
JWT_SECRET=generate-with-python-secrets-module
SECRET_KEY=generate-with-python-secrets-module
APP_SECRET=generate-with-python-secrets-module

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=20
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# MULTI-TENANT / DEVICE SECURITY
# =============================================================================
REQUIRE_DEVICE_ID_ON_LOGIN=true
ENFORCE_IP_WHITELIST=true

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
MAIL_USERNAME=support@primusadmin.in
MAIL_PASSWORD=wfcq egau rthj wlgj
MAIL_FROM=support@primusadmin.in
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_TLS=True
MAIL_SSL=False
MAIL_SUPPRESS_SEND=false

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
APP_BASE_URL=https://primusadmin.in
ENVIRONMENT=production
DEBUG=False

# =============================================================================
# OAUTH CONFIGURATION
# =============================================================================
# Apply real values at deploy time via:
#   scripts/configure_google_oauth.py --client-secret-json <downloaded.json>
# Never commit live credentials to this file. Old credentials
# 812137115166-099fv8u30... were burned and have been deleted in Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_URL=redis://redis:6379/0
REDIS_NAMESPACE=primus

# =============================================================================
# VAULT CONFIGURATION
# =============================================================================
VAULT_ADDR=http://primus-vault:8200
VAULT_TOKEN=your-production-vault-token

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
ALLOW_ALL_CORS=false
# Browsers add the Origin header from whatever URL the page actually
# loaded from — so if your DNS / CDN rewrites primusadmin.in -> www.primusadmin.in
# (very common), you MUST list both the apex AND the www. variant. Otherwise
# CORS preflight blocks every authenticated XHR. The middleware also runs a
# defensive regex match (^https://(www\.)?(primustech|primusadmin|primusinfotech)\.(in|com)$),
# so missing entries are forgiven, but listing them explicitly is cleaner.
ALLOWED_ORIGINS=https://primustech.in,https://www.primustech.in,https://primusadmin.in,https://www.primusadmin.in,https://primusinfotech.in,https://www.primusinfotech.in
