# =============================================================================
# PRIMUS BACKEND - ENVIRONMENT CONFIGURATION (DEVELOPMENT)
# =============================================================================
# Copy this file to .env and update with your actual values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Primus is PostgreSQL-only.
DATABASE_URL=postgresql+psycopg2://primus_user:PrimusDbSecureP4ssw0rd!@localhost:5432/primus_db

# Matching Postgres server settings (used by Docker / install scripts)
POSTGRES_USER=primus_user
POSTGRES_PASSWORD=PrimusDbSecureP4ssw0rd!
POSTGRES_DB=primus_db

# =============================================================================
# MULTI-DATABASE CONFIGURATION
# =============================================================================
# Master flag — set to true to enable per-cafe database routing.
# When false (default), all traffic routes to DATABASE_URL (single-DB mode).
MULTI_DB_ENABLED=false

# Global database — stores users, cafes, subscriptions, licenses, financial audit.
# Defaults to DATABASE_URL if not set (safe for migration).
GLOBAL_DATABASE_URL=postgresql+psycopg2://primus_user:PrimusDbSecureP4ssw0rd!@localhost:5432/primus_global

# Admin database URL — needs CREATE DATABASE privilege (superuser recommended).
# Used only by the provisioning script to create new per-cafe databases.
# Defaults to GLOBAL_DATABASE_URL if not set.
ADMIN_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/postgres

# Per-cafe SQLAlchemy connection pool settings
CAFE_DB_ENGINE_CACHE_SIZE=100
CAFE_DB_POOL_SIZE=3
CAFE_DB_MAX_OVERFLOW=5

# =============================================================================
# SECURITY KEYS - CHANGE THESE IN PRODUCTION!
# =============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
SECRET_KEY=your-app-secret-key-change-this-in-production
APP_SECRET=your-app-secret-for-otp-change-this

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=20
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# MULTI-TENANT / DEVICE SECURITY FEATURE FLAGS
# =============================================================================
# Require device_id on login to resolve cafe from device (default: false)
REQUIRE_DEVICE_ID_ON_LOGIN=false
# Enforce IP whitelist per device using allowed_ip_range CIDR (default: false)
ENFORCE_IP_WHITELIST=false
# Enable PostgreSQL Row-Level Security on cafe databases (default: false)
ENABLE_RLS=false

# =============================================================================
# EMAIL CONFIGURATION - Gmail OTP Email Verification
# =============================================================================
MAIL_USERNAME=support@primusadmin.in
MAIL_PASSWORD=wfcq egau rthj wlgj
MAIL_FROM=support@primusadmin.in
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_TLS=True
MAIL_SSL=False
MAIL_SUPPRESS_SEND=false

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# For local development:
APP_BASE_URL=http://localhost:8000
ENVIRONMENT=development
DEBUG=True

# =============================================================================
# OAUTH CONFIGURATION (for social login)
# =============================================================================
GOOGLE_CLIENT_ID=812137115166-099fv8u30homplpf09i5tb76gq3pntrf.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret

# Google OAuth redirect URIs:
# - Local dev:  http://localhost:8000/api/social/auth/google
# - Local dev:  http://127.0.0.1:8000/api/social/auth/google

# =============================================================================
# PAYMENT GATEWAY CONFIGURATION
# =============================================================================
STRIPE_SECRET=your-stripe-secret-key
STRIPE_CURRENCY=usd
STRIPE_SUCCESS_URL=http://localhost:5173/payment/success
STRIPE_CANCEL_URL=http://localhost:5173/payment/cancel

RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_CURRENCY=INR
RAZORPAY_SUCCESS_URL=http://localhost:5173/razorpay/success

# =============================================================================
# REDIS CONFIGURATION (for OTP and caching)
# =============================================================================
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_PASSWORD=
REDIS_NAMESPACE=primus
CACHE_DEFAULT_TTL=300
REDIS_CONNECTION_MAX=50
CACHE_VERSION=v1

# =============================================================================
# OTP CONFIGURATION
# =============================================================================
OTP_TTL_SEC=300
RESEND_COOLDOWN_SEC=30
MAX_SENDS_PER_HOUR=5
MAX_ATTEMPTS=5

# =============================================================================
# VAULT / SECRETS MANAGER CONFIGURATION
# =============================================================================
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=dev-root-token-change-in-production

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
ALLOW_ALL_CORS=true
ALLOWED_ORIGINS=https://primusinfotech.in,https://primusadmin.in,http://localhost:5173,http://127.0.0.1:5173

# =============================================================================
# CASHFREE PAYMENTS (UPI QR kiosk flow)
# =============================================================================
# Cashfree Payments PG credentials. Get them from the Cashfree dashboard →
# Developers → API Keys. "sandbox" for testing, "production" for live.
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_WEBHOOK_SECRET=
CASHFREE_ENV=sandbox
# Public HTTPS URL that Cashfree can reach. In production this should be
# your Azure backend public URL:
# CASHFREE_NOTIFY_URL=https://api.primustech.in/api/v1/payment/cashfree/webhook
CASHFREE_NOTIFY_URL=
