# =============================================================================
# ClutchHH Backend — Production Environment Template
# Azure VM: ClutchHH | IP: 20.55.214.91 | Ubuntu 24.04 LTS
# =============================================================================
# HOW TO USE:
#   1. cp backend/.env.template backend/.env
#   2. Replace every FILL_IN / GENERATE placeholder
#   3. Never commit backend/.env to version control
#
# Generate secrets (run this 3x for SECRET_KEY, JWT_SECRET, APP_SECRET):
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# =============================================================================

# =============================================================================
# DATABASE CONFIGURATION
# PostgreSQL runs natively on the host VM (set up by setup_observability.sh).
# Docker containers reach it via host.docker.internal (extra_hosts: host-gateway).
# The password here MUST match PG_PASS in setup_observability.sh.
# =============================================================================
DATABASE_URL=postgresql+psycopg2://clutchhh_user:FILL_IN_PG_PASS@host.docker.internal:5432/clutchhh_db
GLOBAL_DATABASE_URL=postgresql+psycopg2://clutchhh_user:FILL_IN_PG_PASS@host.docker.internal:5432/clutchhh_global
ADMIN_DATABASE_URL=postgresql+psycopg2://clutchhh_user:FILL_IN_PG_PASS@host.docker.internal:5432/clutchhh_db

# Used by the Superset container to connect to its metadata DB
POSTGRES_USER=clutchhh_user
POSTGRES_PASSWORD=FILL_IN_PG_PASS

# =============================================================================
# MULTI-DATABASE (multi-tenant cafe databases)
# =============================================================================
MULTI_DB_ENABLED=false
CAFE_DB_ENGINE_CACHE_SIZE=100
CAFE_DB_POOL_SIZE=3
CAFE_DB_MAX_OVERFLOW=5

# =============================================================================
# SECURITY KEYS — Generate all three independently, never reuse
# python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# =============================================================================
SECRET_KEY=GENERATE
JWT_SECRET=GENERATE
APP_SECRET=GENERATE

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=20
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
ENVIRONMENT=production
DEBUG=False
APP_BASE_URL=http://20.55.214.91:8000

# =============================================================================
# CORS CONFIGURATION
# Add your domain(s) once DNS is configured
# =============================================================================
ALLOW_ALL_CORS=false
ALLOWED_ORIGINS=https://primustech.in,https://www.primustech.in,https://primusadmin.in,https://www.primusadmin.in,https://api.primustech.in,https://api.primusadmin.in,https://primusinfotech.com,https://www.primusinfotech.com,http://20.55.214.91,http://localhost:5173,http://localhost:3000,http://localhost:1420

# =============================================================================
# SECURITY FEATURE FLAGS
# Enable after testing each feature end-to-end
# =============================================================================
REQUIRE_DEVICE_ID_ON_LOGIN=false
ENFORCE_IP_WHITELIST=false
ENABLE_RLS=false
ENABLE_TOTP_2FA=false
ENABLE_CSRF_PROTECTION=true
RATE_LIMIT_PER_MINUTE=1000
RATE_LIMIT_BURST=100
MAX_REQUEST_SIZE_BYTES=10485760

# =============================================================================
# REDIS CONFIGURATION
# The "redis" hostname resolves to the clutchhh_redis container
# =============================================================================
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=
REDIS_NAMESPACE=clutchhh
CACHE_DEFAULT_TTL=300
CACHE_VERSION=v1
REDIS_CONNECTION_MAX=50

# =============================================================================
# VAULT CONFIGURATION
# Vault runs natively on the host. Containers reach it via host.docker.internal.
# VAULT_TOKEN: use the Root Token printed by setup_observability.sh initially.
# In production, replace with a scoped token (vault/init/policy-clutchhh.hcl).
# =============================================================================
VAULT_ADDR=http://host.docker.internal:8200
VAULT_TOKEN=FILL_IN_FROM_VAULT_INIT_OUTPUT

# =============================================================================
# EMAIL CONFIGURATION (Gmail SMTP)
# Use a Gmail App Password (myaccount.google.com → Security → App Passwords)
# =============================================================================
MAIL_USERNAME=FILL_IN
MAIL_PASSWORD=FILL_IN
MAIL_FROM=FILL_IN
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_TLS=True
MAIL_SSL=False
MAIL_SUPPRESS_SEND=false

# OTP settings
OTP_TTL_SEC=300
RESEND_COOLDOWN_SEC=30
MAX_SENDS_PER_HOUR=5
MAX_ATTEMPTS=5

# =============================================================================
# SUPERSET (Analytics Dashboard)
# =============================================================================
SUPERSET_SECRET_KEY=GENERATE
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASS=FILL_IN
SUPERSET_ADMIN_EMAIL=admin@clutchhh.io
SUPERSET_BASE_URL=http://20.55.214.91:8088

# =============================================================================
# CLOUDFLARE TUNNEL (optional — leave blank to disable)
# Get token from: dash.cloudflare.com → Zero Trust → Access → Tunnels
# =============================================================================
CLOUDFLARE_TUNNEL_TOKEN=

# =============================================================================
# OAUTH PROVIDERS (optional — leave blank to disable each provider)
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Optional OIDC (Keycloak, Auth0, etc.) — leave blank to disable
OIDC_ISSUER=
OIDC_AUDIENCE=

# =============================================================================
# PAYMENT GATEWAYS (optional — leave blank to disable)
# =============================================================================
STRIPE_SECRET=
STRIPE_CURRENCY=usd
STRIPE_SUCCESS_URL=http://20.55.214.91/payment/success
STRIPE_CANCEL_URL=http://20.55.214.91/payment/cancel

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_CURRENCY=INR
RAZORPAY_SUCCESS_URL=http://20.55.214.91/razorpay/success

UPI_PROVIDER=razorpay
UPI_MERCHANT_VPA=
UPI_WEBHOOK_SECRET=

# =============================================================================
# PGBOUNCER (optional connection pooler — disabled by default)
# =============================================================================
USE_PGBOUNCER=false
