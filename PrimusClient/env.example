# =============================================================================
# PRIMUS CLIENT - ENVIRONMENT CONFIGURATION
# =============================================================================

# Backend Configuration
# For local dev: http://localhost:8000
# For production: https://api.primusadmin.in
VITE_BACKEND_URL=http://localhost:8000

# Long Polling Configuration (Replaced WebSockets)
VITE_POLL_INTERVAL_MS=500
VITE_LONG_POLL_TIMEOUT_SEC=25

# License Configuration
VITE_LICENSE_KEY=your-license-key-here

# Development Configuration
VITE_DEV_MODE=true
VITE_DEBUG_LOGS=true

# UI Configuration
VITE_KIOSK_MODE=true
VITE_ALLOW_DEVELOPER_TOOLS=false

# API Timeouts (in milliseconds)
VITE_API_TIMEOUT=30000
VITE_RECONNECT_INTERVAL=5000

# =============================================================================
# GOOGLE SIGN-IN (Web client ID from Google Cloud Console → Credentials)
# =============================================================================
# Must match GOOGLE_CLIENT_ID set on the backend; backend verifies the `aud`
# claim against this value when validating ID tokens. Vite bakes this into
# the kiosk bundle at build time (build-time only — runtime overrides have
# no effect). Run scripts/configure_google_oauth.py to populate it from the
# client_secret_*.json downloaded from Cloud Console.
VITE_GOOGLE_WEB_CLIENT_ID=
