# =============================================================================
# PRIMUS CLIENT - ENVIRONMENT CONFIGURATION
# =============================================================================

# Backend Configuration
# For local dev: http://localhost:8000
# For production: https://api.primusadmin.in
VITE_BACKEND_URL=http://localhost:8000

# Long Polling Configuration (Replaced WebSockets)
VITE_POLL_INTERVAL_MS=500
VITE_LONG_POLL_TIMEOUT_SEC=25

# License Configuration
VITE_LICENSE_KEY=your-license-key-here

# Development Configuration
VITE_DEV_MODE=true
VITE_DEBUG_LOGS=true

# UI Configuration
VITE_KIOSK_MODE=true
VITE_ALLOW_DEVELOPER_TOOLS=false

# API Timeouts (in milliseconds)
VITE_API_TIMEOUT=30000
VITE_RECONNECT_INTERVAL=5000
