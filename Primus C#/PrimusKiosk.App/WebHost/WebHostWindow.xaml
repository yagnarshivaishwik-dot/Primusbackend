<Window x:Class="PrimusKiosk.App.WebHost.WebHostWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Title="Primus Client"
        Background="#020617">
  <Grid>
    <wv2:WebView2 x:Name="WebView" />

    <!-- Optional splash shown until WebView2 navigates successfully. Hidden
         once the React app signals it is ready via window.__TAURI__ ping. -->
    <Border x:Name="Splash" Background="#020617">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Text="PRIMUS"
                   FontSize="44"
                   FontWeight="Black"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,16" />
        <TextBlock x:Name="SplashMessage"
                   Text="Loading..."
                   FontSize="13"
                   Foreground="#9CA3AF"
                   HorizontalAlignment="Center" />
        <ProgressBar IsIndeterminate="True"
                     Width="220"
                     Height="3"
                     Margin="0,18,0,0"
                     Foreground="#6366F1"
                     Background="#1F2937"
                     BorderThickness="0" />
      </StackPanel>
    </Border>
  </Grid>
</Window>
