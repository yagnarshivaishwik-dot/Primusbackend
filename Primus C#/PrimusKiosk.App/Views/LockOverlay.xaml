<UserControl x:Class="PrimusKiosk.App.Views.LockOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:PrimusKiosk.App.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:LockOverlayViewModel}">
  <Grid Background="#CC020617">
    <Border Style="{StaticResource CardSurface}"
            MaxWidth="480"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
      <StackPanel>
        <TextBlock Text="Station locked"
                   Style="{StaticResource TitleText}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,12" />
        <TextBlock Text="{Binding Message}"
                   Style="{StaticResource BodyText}"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8" />
        <TextBlock Text="Please contact staff to continue."
                   Style="{StaticResource MutedText}"
                   TextAlignment="Center" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
