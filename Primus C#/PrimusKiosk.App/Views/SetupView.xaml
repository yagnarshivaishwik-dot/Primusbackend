<UserControl x:Class="PrimusKiosk.App.Views.SetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:PrimusKiosk.App.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:SetupViewModel}">
  <Grid>
    <Border Style="{StaticResource CardSurface}"
            MaxWidth="520"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
      <StackPanel>
        <!-- Gradient logo circle -->
        <Border Width="72" Height="72" CornerRadius="36" HorizontalAlignment="Center" Margin="0,0,0,16">
          <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
              <GradientStop Color="#10B981" Offset="0" />
              <GradientStop Color="#059669" Offset="1" />
            </LinearGradientBrush>
          </Border.Background>
          <TextBlock Text="&#xE7F8;" FontFamily="{StaticResource IconFontFamily}"
                     FontSize="32" Foreground="White"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>

        <TextBlock Text="Primus Kiosk Setup" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" />
        <TextBlock Text="Enter the backend URL and your license key to register this PC."
                   Style="{StaticResource MutedText}"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   Margin="0,4,0,24" />

        <TextBlock Text="Backend URL (https://...)" Style="{StaticResource MutedText}" Margin="0,0,0,4" />
        <TextBox Text="{Binding ApiBaseUrl, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Text="PC name" Style="{StaticResource MutedText}" Margin="0,12,0,4" />
        <TextBox Text="{Binding PcName, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Text="License key" Style="{StaticResource MutedText}" Margin="0,12,0,4" />
        <TextBox Text="{Binding LicenseKey, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="{StaticResource DangerBrush}"
                   FontSize="12"
                   Margin="0,12,0,0"
                   TextWrapping="Wrap"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NotNullToVisibility}}" />

        <Button Content="Register device"
                Command="{Binding RegisterCommand}"
                Margin="0,20,0,0"
                Height="44"
                FontSize="15" />

        <TextBlock Text="{Binding BusyMessage}"
                   Style="{StaticResource MutedText}"
                   HorizontalAlignment="Center"
                   Margin="0,12,0,0"
                   Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
