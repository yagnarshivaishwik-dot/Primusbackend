<UserControl x:Class="PrimusKiosk.App.Views.SessionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:PrimusKiosk.App.ViewModels"
             xmlns:views="clr-namespace:PrimusKiosk.App.Views"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:SessionViewModel}">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Header (mirrors React: logo + welcome / wallet chip / logout) -->
    <Border Grid.Row="0" Background="#99111827" BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="0,0,0,1" Padding="24,14">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
          <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,12,0">
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#6366F1" Offset="0" />
                <GradientStop Color="#4F46E5" Offset="1" />
              </LinearGradientBrush>
            </Border.Background>
            <TextBlock Text="&#xE7FC;" FontFamily="{StaticResource IconFontFamily}"
                       Foreground="White" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Primus Gaming Cafe" FontWeight="Bold" FontSize="18" />
            <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="12">
              <Run Text="Welcome, " />
              <Run Text="{Binding UserName}" />
              <Run Text="   " />
              <Run Text="{Binding ConnectionText}" />
            </TextBlock>
          </StackPanel>
        </StackPanel>

        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
          <Border Background="#66334155" CornerRadius="10" Padding="14,8" Margin="0,0,12,0">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8C7;" FontFamily="{StaticResource IconFontFamily}" Foreground="{StaticResource Indigo300}" Margin="0,0,6,0" />
              <TextBlock Text="{Binding WalletBalance}" FontWeight="SemiBold" Margin="0,0,14,0" />
              <TextBlock Text="&#xEA1F;" FontFamily="{StaticResource IconFontFamily}" Foreground="{StaticResource Amber500}" Margin="0,0,6,0" />
              <TextBlock Text="{Binding WalletCoins}" FontWeight="SemiBold" />
            </StackPanel>
          </Border>
          <Border Background="#66334155" CornerRadius="10" Padding="10,6" Margin="0,0,12,0">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="{Binding CpuText}" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,10,0" />
              <TextBlock Text="{Binding RamText}" FontSize="11" Foreground="{StaticResource TextSecondary}" />
            </StackPanel>
          </Border>
          <Button Content="Sign out" Command="{Binding LogoutCommand}" Style="{StaticResource SecondaryButton}" Padding="12,6" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Body: sidebar + main + chat -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="320" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="320" />
      </Grid.ColumnDefinitions>

      <!-- SIDEBAR: session status, quick top-up, quick access -->
      <Border Grid.Column="0" Background="#4D111827" BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="0,0,1,0" Padding="20">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel>
            <Border Style="{StaticResource CardSurface}" Padding="18" Margin="0,0,0,16">
              <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                  <TextBlock Text="&#xE7F4;" FontFamily="{StaticResource IconFontFamily}" Foreground="{StaticResource Indigo400}" FontSize="18" Margin="0,0,8,0" />
                  <TextBlock Text="Session Status" Style="{StaticResource TitleText}" FontSize="16" />
                </StackPanel>

                <Border Background="{StaticResource Slate950}" CornerRadius="12" Padding="18" Margin="0,0,0,12">
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding SessionTime}" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding SessionStatusText}" Style="{StaticResource MutedText}" HorizontalAlignment="Center" Margin="0,6,0,0" />
                    <TextBlock Text="{Binding RemainingTimeText}" HorizontalAlignment="Center" Foreground="{StaticResource Indigo300}" FontSize="12" Margin="0,6,0,0" />
                  </StackPanel>
                </Border>

                <Button Content="Start session" Command="{Binding StartSessionCommand}" />
                <Button Content="End session" Command="{Binding EndSessionCommand}" Style="{StaticResource DangerButton}" />
              </StackPanel>
            </Border>

            <Border Style="{StaticResource CardSurface}" Padding="18" Margin="0,0,0,16">
              <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                  <TextBlock Text="&#xE710;" FontFamily="{StaticResource IconFontFamily}" Foreground="{StaticResource Emerald400}" Margin="0,0,8,0" />
                  <TextBlock Text="Quick Top-up" Style="{StaticResource TitleText}" FontSize="16" />
                </StackPanel>
                <UniformGrid Columns="2" Rows="2">
                  <Button Content="$5"  Command="{Binding TopUpCommand}" CommandParameter="5"  Style="{StaticResource SecondaryButton}" Margin="3" />
                  <Button Content="$10" Command="{Binding TopUpCommand}" CommandParameter="10" Style="{StaticResource SecondaryButton}" Margin="3" />
                  <Button Content="$20" Command="{Binding TopUpCommand}" CommandParameter="20" Style="{StaticResource SecondaryButton}" Margin="3" />
                  <Button Content="$50" Command="{Binding TopUpCommand}" CommandParameter="50" Style="{StaticResource SecondaryButton}" Margin="3" />
                </UniformGrid>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource CardSurface}" Padding="18">
              <StackPanel>
                <TextBlock Text="Quick Access" Style="{StaticResource TitleText}" FontSize="16" Margin="0,0,0,10" />
                <Button Content="Shop"        HorizontalContentAlignment="Left" Padding="12,8" Style="{StaticResource SecondaryButton}" />
                <Button Content="Leaderboard" HorizontalContentAlignment="Left" Padding="12,8" Style="{StaticResource SecondaryButton}" />
                <Button Content="Profile"     HorizontalContentAlignment="Left" Padding="12,8" Style="{StaticResource SecondaryButton}" />
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- MAIN: game grid or game detail -->
      <Grid Grid.Column="1" Margin="24">
        <!-- Game detail view when one is selected -->
        <Grid Visibility="{Binding SelectedGame, Converter={StaticResource NullToVisibility}}">
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="520">
            <Border Height="260" Width="180" CornerRadius="14" HorizontalAlignment="Center">
              <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                  <GradientStop Color="#6366F1" Offset="0" />
                  <GradientStop Color="#312E81" Offset="1" />
                </LinearGradientBrush>
              </Border.Background>
              <TextBlock Text="&#xE7FC;" FontFamily="{StaticResource IconFontFamily}" Foreground="White" FontSize="72" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="{Binding SelectedGame.Name}" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,20,0,6" />
            <TextBlock Text="{Binding SelectedGame.Description}" Style="{StaticResource MutedText}" TextAlignment="Center" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
              <Button Content="Back" Command="{Binding DeselectGameCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0" />
              <Button Content="Launch Game" Command="{Binding LaunchGameCommand}" CommandParameter="{Binding SelectedGame}" />
            </StackPanel>
          </StackPanel>
        </Grid>

        <!-- Game grid when no game selected -->
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <Grid.Style>
            <Style TargetType="Grid">
              <Setter Property="Visibility" Value="Visible" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedGame, Converter={StaticResource NullToVisibility}}" Value="Visible">
                  <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Grid.Style>

          <StackPanel Grid.Row="0">
            <TextBlock Text="Available Games" Style="{StaticResource TitleText}" />
            <TextBlock Style="{StaticResource MutedText}" Margin="0,4,0,0">
              <Run Text="{Binding Games.Count, Mode=OneWay}" />
              <Run Text=" games in catalog" />
            </TextBlock>
          </StackPanel>

          <ScrollViewer Grid.Row="1" Margin="0,20,0,0" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Games}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel IsItemsHost="True" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Width="220" Margin="8" Background="{StaticResource SurfaceBrush}"
                          CornerRadius="14" BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="1"
                          Cursor="Hand">
                    <Border.Effect>
                      <DropShadowEffect Color="Black" BlurRadius="12" Opacity="0.35" ShadowDepth="3" />
                    </Border.Effect>
                    <Border.InputBindings>
                      <MouseBinding MouseAction="LeftClick"
                                    Command="{Binding DataContext.SelectGameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}" />
                    </Border.InputBindings>
                    <StackPanel>
                      <Border Height="130" CornerRadius="14,14,0,0">
                        <Border.Background>
                          <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#4F46E5" Offset="0" />
                            <GradientStop Color="#312E81" Offset="1" />
                          </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="&#xE7FC;" FontFamily="{StaticResource IconFontFamily}"
                                   Foreground="White" FontSize="52" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.9" />
                      </Border>
                      <StackPanel Margin="14">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Description}" Style="{StaticResource MutedText}" TextWrapping="Wrap" MaxHeight="36" />
                        <Button Content="Play"
                                Margin="0,10,0,0"
                                Command="{Binding DataContext.LaunchGameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}" />
                      </StackPanel>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Grid>

      <!-- RIGHT: chat panel -->
      <views:ChatPanel Grid.Column="2" DataContext="{Binding Chat}" Margin="0,20,20,20" />
    </Grid>
  </Grid>
</UserControl>
