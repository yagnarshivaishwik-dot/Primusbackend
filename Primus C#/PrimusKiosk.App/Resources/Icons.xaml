<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

  <!-- Segoe Fluent Icons glyphs used as Lucide replacements.
       Referenced like: <TextBlock FontFamily="Segoe Fluent Icons" Text="{StaticResource Icon.Gamepad}" /> -->
  <FontFamily x:Key="IconFontFamily">Segoe Fluent Icons, Segoe MDL2 Assets</FontFamily>

  <sys:String x:Key="Icon.Gamepad">&#xE7FC;</sys:String>
  <sys:String x:Key="Icon.Wallet">&#xE8C7;</sys:String>
  <sys:String x:Key="Icon.Chat">&#xE8BD;</sys:String>
  <sys:String x:Key="Icon.Lock">&#xE72E;</sys:String>
  <sys:String x:Key="Icon.Unlock">&#xE785;</sys:String>
  <sys:String x:Key="Icon.Power">&#xE7E8;</sys:String>
  <sys:String x:Key="Icon.Settings">&#xE713;</sys:String>
  <sys:String x:Key="Icon.Info">&#xE946;</sys:String>
  <sys:String x:Key="Icon.Warning">&#xE7BA;</sys:String>
  <sys:String x:Key="Icon.Error">&#xE783;</sys:String>
  <sys:String x:Key="Icon.Signal">&#xE701;</sys:String>
  <sys:String x:Key="Icon.CloudOff">&#xF53F;</sys:String>

</ResourceDictionary>
