<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Tailwind-inspired palette tokens. Keep names stable; views reference these by key. -->
  <SolidColorBrush x:Key="Slate950" Color="#020617" />
  <SolidColorBrush x:Key="Slate900" Color="#0F172A" />
  <SolidColorBrush x:Key="Slate800" Color="#1E293B" />
  <SolidColorBrush x:Key="Slate700" Color="#334155" />
  <SolidColorBrush x:Key="Slate600" Color="#475569" />
  <SolidColorBrush x:Key="Slate500" Color="#64748B" />
  <SolidColorBrush x:Key="Slate400" Color="#94A3B8" />
  <SolidColorBrush x:Key="Slate300" Color="#CBD5E1" />
  <SolidColorBrush x:Key="Slate100" Color="#F1F5F9" />
  <SolidColorBrush x:Key="Slate50"  Color="#F8FAFC" />

  <SolidColorBrush x:Key="Indigo500" Color="#6366F1" />
  <SolidColorBrush x:Key="Indigo400" Color="#818CF8" />
  <SolidColorBrush x:Key="Indigo300" Color="#A5B4FC" />

  <SolidColorBrush x:Key="Emerald500" Color="#10B981" />
  <SolidColorBrush x:Key="Emerald400" Color="#34D399" />
  <SolidColorBrush x:Key="Amber500"   Color="#F59E0B" />
  <SolidColorBrush x:Key="Rose500"    Color="#F43F5E" />
  <SolidColorBrush x:Key="Rose400"    Color="#FB7185" />

  <SolidColorBrush x:Key="PrimaryBrush"      Color="#6366F1" />
  <SolidColorBrush x:Key="PrimaryDarkBrush"  Color="#4F46E5" />
  <SolidColorBrush x:Key="SurfaceBrush"      Color="#141926" />
  <SolidColorBrush x:Key="SurfaceAltBrush"   Color="#111827" />
  <SolidColorBrush x:Key="BorderSoftBrush"   Color="#1F2937" />
  <SolidColorBrush x:Key="TextPrimary"       Color="#F9FAFB" />
  <SolidColorBrush x:Key="TextSecondary"     Color="#9CA3AF" />
  <SolidColorBrush x:Key="TextMuted"         Color="#6B7280" />
  <SolidColorBrush x:Key="DangerBrush"       Color="#F97373" />

  <LinearGradientBrush x:Key="ShellBackgroundGradient" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#020617" Offset="0" />
    <GradientStop Color="#0F172A" Offset="1" />
  </LinearGradientBrush>

</ResourceDictionary>
