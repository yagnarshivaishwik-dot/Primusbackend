<Application x:Class="PrimusKiosk.App.PrimusApplication"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:PrimusKiosk.App.Views"
             xmlns:vm="clr-namespace:PrimusKiosk.App.ViewModels"
             xmlns:converters="clr-namespace:PrimusKiosk.App.Converters">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Resources/Brushes.xaml" />
        <ResourceDictionary Source="/Resources/Typography.xaml" />
        <ResourceDictionary Source="/Resources/Icons.xaml" />
        <ResourceDictionary Source="/Resources/Controls.xaml" />
      </ResourceDictionary.MergedDictionaries>

      <!-- Converters -->
      <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
      <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
      <converters:NullToVisibilityConverter x:Key="NotNullToVisibility" WhenNull="Visible" WhenNotNull="Collapsed" />
      <converters:SecondsToClockConverter x:Key="SecondsToClock" />
      <converters:ConnectionStateToBrushConverter x:Key="ConnectionStateToBrush" />
      <converters:ConnectionStateToTextConverter x:Key="ConnectionStateToText" />

      <!-- View-model → View templates (data-template driven navigation) -->
      <DataTemplate DataType="{x:Type vm:LoadingViewModel}">
        <views:LoadingView />
      </DataTemplate>
      <DataTemplate DataType="{x:Type vm:SetupViewModel}">
        <views:SetupView />
      </DataTemplate>
      <DataTemplate DataType="{x:Type vm:LoginViewModel}">
        <views:LoginView />
      </DataTemplate>
      <DataTemplate DataType="{x:Type vm:SessionViewModel}">
        <views:SessionView />
      </DataTemplate>
    </ResourceDictionary>
  </Application.Resources>
</Application>
