<Window x:Class="PrimusKiosk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:PrimusKiosk.Views"
        mc:Ignorable="d"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Title="Primus Kiosk"
        Background="#000000">
  <Grid>
    <Grid.Background>
      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource BackgroundGradientStart}" Offset="0" />
        <GradientStop Color="{StaticResource BackgroundGradientEnd}" Offset="1" />
      </LinearGradientBrush>
    </Grid.Background>

    <!-- Root content: swap between login and session -->
    <ContentControl x:Name="RootContent" />

    <!-- Simple lock overlay placeholder (activated by admin lock command) -->
    <Border x:Name="LockOverlay"
            Background="#CC000000"
            Visibility="Collapsed">
      <StackPanel HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  MaxWidth="480"
                  Margin="24">
        <TextBlock Text="This station is locked by administrator"
                   FontSize="24"
                   FontWeight="Bold"
                   TextAlignment="Center"
                   Margin="0,0,0,12" />
        <TextBlock x:Name="LockMessage"
                   Text="Please contact staff to unlock."
                   FontSize="16"
                   TextAlignment="Center"
                   Foreground="{StaticResource TextSecondary}" />
      </StackPanel>
    </Border>
  </Grid>
</Window>


