<UserControl x:Class="PrimusKiosk.Views.SessionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="280" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- Sidebar approximating Primus session screen -->
    <Border Grid.Column="0"
            Background="#111827"
            BorderBrush="{StaticResource BorderBrushSoft}"
            BorderThickness="0,0,1,0"
            Padding="16">
      <StackPanel>
        <TextBlock Text="Session Status"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16" />

        <Border Background="#020617"
                CornerRadius="10"
                Padding="16"
                Margin="0,0,0,12">
          <StackPanel HorizontalAlignment="Center">
            <TextBlock Text="{Binding SessionTime}"
                       FontSize="24"
                       FontWeight="Bold"
                       HorizontalAlignment="Center" />
            <TextBlock Text="{Binding SessionStatusText}"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondary}"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0" />
          </StackPanel>
        </Border>

        <Button Content="Start Session"
                Command="{Binding StartSessionCommand}"
                Margin="0,4,0,0" />
        <Button Content="End Session"
                Command="{Binding EndSessionCommand}"
                Margin="0,4,0,0"
                Style="{StaticResource SecondaryButton}" />

        <TextBlock Text="Wallet"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,20,0,8" />
        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
          <TextBlock Text="Balance:" Foreground="{StaticResource TextSecondary}" Margin="0,0,4,0" />
          <TextBlock Text="{Binding WalletBalanceFormatted}" />
        </StackPanel>
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="Coins:" Foreground="{StaticResource TextSecondary}" Margin="0,0,4,0" />
          <TextBlock Text="{Binding WalletCoinsFormatted}" />
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Main games grid placeholder -->
    <Grid Grid.Column="1" Margin="20">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="SpaceBetween">
        <StackPanel>
          <TextBlock Text="Available Games"
                     FontSize="22"
                     FontWeight="Bold"
                     Margin="0,0,0,4" />
          <TextBlock Text="{Binding GamesSubtitle}"
                     Foreground="{StaticResource TextSecondary}" />
        </StackPanel>

        <StackPanel HorizontalAlignment="Right">
          <TextBlock Text="{Binding ConnectionStatusText}"
                     Foreground="{Binding ConnectionStatusBrush}"
                     HorizontalAlignment="Right" />
        </StackPanel>
      </StackPanel>

      <ItemsControl Grid.Row="1"
                    Margin="0,16,0,0"
                    ItemsSource="{Binding Games}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel IsItemsHost="True" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Width="200"
                    Margin="8"
                    Background="#020617"
                    CornerRadius="10"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1">
              <StackPanel>
                <Border Height="110"
                        Background="#111827"
                        CornerRadius="10,10,0,0" />
                <StackPanel Margin="8">
                  <TextBlock Text="{Binding Name}"
                             FontWeight="SemiBold"
                             Margin="0,0,0,4" />
                  <TextBlock Text="{Binding Description}"
                             Foreground="{StaticResource TextSecondary}"
                             FontSize="11"
                             TextWrapping="Wrap"
                             MaxHeight="40" />
                  <Button Content="Play"
                          Margin="0,8,0,0"
                          Command="{Binding DataContext.LaunchGameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}" />
                </StackPanel>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </Grid>
  </Grid>
</UserControl>


