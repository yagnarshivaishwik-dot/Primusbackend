<UserControl x:Class="PrimusKiosk.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
  <Grid>
    <Grid Background="#00000000">
      <Grid.RowDefinitions>
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24">
        <Border Background="{StaticResource CardBackground}"
                CornerRadius="18"
                Padding="32"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                Effect="{DynamicResource DropShadowEffect}">
          <StackPanel Width="420">
            <!-- Heading approximating Primus auth combined screen -->
            <StackPanel Margin="0,0,0,24" HorizontalAlignment="Center">
              <TextBlock Text="PRIMUS"
                         FontSize="40"
                         FontWeight="Black"
                         TextAlignment="Center"
                         Margin="0,0,0,4" />
              <TextBlock Text="Log in with your Primus credentials"
                         FontSize="14"
                         Foreground="{StaticResource TextSecondary}"
                         TextAlignment="Center" />
            </StackPanel>

            <StackPanel>
              <TextBlock Text="Email or Username" FontSize="13" Margin="0,4,0,0" />
              <TextBox Text="{Binding UsernameOrEmail, UpdateSourceTrigger=PropertyChanged}" />

              <TextBlock Text="Password" FontSize="13" Margin="0,12,0,0" />
              <PasswordBox x:Name="PasswordBox"
                           PasswordChanged="PasswordBox_OnPasswordChanged" />

              <TextBlock Text="{Binding ErrorMessage}"
                         Foreground="#F97373"
                         FontSize="12"
                         Margin="0,8,0,0"
                         TextWrapping="Wrap" />

              <Button Content="{Binding LoginButtonText}"
                      Margin="0,16,0,0"
                      Height="40"
                      Command="{Binding LoginCommand}" />
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>
    </Grid>
  </Grid>
</UserControl>


