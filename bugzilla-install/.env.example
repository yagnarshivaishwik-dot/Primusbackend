# Bugzilla install configuration — copy to `.env`, fill in, then run install.sh
# Never commit the real .env (see .gitignore).

# ── Web ──────────────────────────────────────────────────────────────
DOMAIN=bugzilla.example.com
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=                         # leave blank to auto-generate (saved to /root/.bugzilla-admin-password)

# ── Bugzilla source ──────────────────────────────────────────────────
BUGZILLA_VERSION=release-5.2-stable     # git branch or tag
INSTALL_DIR=/var/www/bugzilla

# ── Database (MariaDB, local) ────────────────────────────────────────
DB_NAME=bugs
DB_USER=bugs
DB_PASS=                                # required; pick a strong password
DB_HOST=localhost

# ── SMTP relay ───────────────────────────────────────────────────────
# Azure blocks port 25 outbound on most VMs — you MUST use a relay (587/STARTTLS).
# Examples: SendGrid, Mailgun, Azure Communication Services SMTP, Office365.
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey                        # SendGrid uses literal "apikey"
SMTP_PASS=
SMTP_FROM=bugzilla@example.com

# ── TLS (Let's Encrypt) ──────────────────────────────────────────────
ENABLE_TLS=true                         # set false for staging / IP-only access
LE_EMAIL=admin@example.com              # Let's Encrypt contact

# ── Apache port ──────────────────────────────────────────────────────
# 80 by default. Pick something else (e.g. 8081) if another service
# (docker-proxy, FastAPI, nginx) is already on 80. Note: Let's Encrypt
# HTTP-01 challenge requires port 80, so TLS+non-80 is unsupported.
APACHE_PORT=80
